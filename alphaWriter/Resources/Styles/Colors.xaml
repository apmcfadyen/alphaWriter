<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Backgrounds - three levels of depth -->
    <Color x:Key="SurfaceDeep">#1A1A1F</Color>
    <Color x:Key="SurfaceMid">#22222A</Color>
    <Color x:Key="SurfaceRaised">#2A2A35</Color>
    <Color x:Key="SurfaceSelected">#313145</Color>
    <Color x:Key="SurfaceHover">#2E2E3A</Color>

    <!-- Borders and separators -->
    <Color x:Key="BorderSubtle">#3A3A48</Color>
    <Color x:Key="BorderMedium">#4A4A5C</Color>
    <Color x:Key="BorderAccent">#6A6A9A</Color>

    <!-- Text hierarchy -->
    <Color x:Key="TextPrimary">#E8E4DC</Color>
    <Color x:Key="TextSecondary">#9E9AA0</Color>
    <Color x:Key="TextDisabled">#5A5A6A</Color>
    <Color x:Key="TextAccent">#A89EC9</Color>

    <!-- Accent / interactive -->
    <Color x:Key="AccentPrimary">#7B6FA8</Color>
    <Color x:Key="AccentHover">#9080C0</Color>
    <Color x:Key="AccentPressed">#6058A0</Color>
    <Color x:Key="AccentDanger">#B05060</Color>
    <Color x:Key="AccentDangerHover">#C06070</Color>

    <!-- Editor surface -->
    <Color x:Key="EditorBackground">#1E1E28</Color>
    <Color x:Key="EditorText">#E8E4DC</Color>

    <!-- Toolbar -->
    <Color x:Key="ToolbarBackground">#1E1E26</Color>
    <Color x:Key="ToolbarButtonActive">#3D3D55</Color>

    <!-- Word count badge -->
    <Color x:Key="WordCountBackground">#2A2A38</Color>
    <Color x:Key="WordCountText">#7A8A7A</Color>

</ResourceDictionary>
