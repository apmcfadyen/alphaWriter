<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:alphaWriter"
             xmlns:converters="clr-namespace:alphaWriter.Converters"
             x:Class="alphaWriter.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:ImagePathConverter x:Key="ImagePathConverter" />
            <converters:SceneStatusColorConverter x:Key="SceneStatusColorConverter" />
            <converters:SceneStatusDisplayConverter x:Key="SceneStatusDisplayConverter" />
            <converters:IsNotNullOrEmptyConverter x:Key="IsNotNullOrEmptyConverter" />
            <converters:IsNotZeroConverter x:Key="IsNotZeroConverter" />
            <converters:IsNotSceneConverter x:Key="IsNotSceneConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
